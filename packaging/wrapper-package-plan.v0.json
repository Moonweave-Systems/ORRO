{
  "kind": "orro-wrapper-package-plan",
  "schema_version": "0.1",
  "status": "publishable-not-published",
  "package_goal": "single user-facing ORRO install that delegates in-process to a compatible witnessd runtime",
  "current_command_source": "ORRO-owned orro console script",
  "published_package": false,
  "phases": [
    {
      "phase": "bootstrap",
      "status": "current",
      "description": "Use ORRO repo metadata and bootstrap planner to prepare or check pinned local engine checkouts.",
      "contains_engine_logic": false
    },
    {
      "phase": "thin-wrapper",
      "status": "publishable",
      "description": "Expose orro and the orro-wrapper compatibility alias from the canonical product package with in-process witnessd delegation.",
      "contains_engine_logic": false
    },
    {
      "phase": "command-migration",
      "status": "complete",
      "description": "Record the completed ORRO-owned orro command migration while retaining orro-wrapper as a compatibility alias.",
      "contains_engine_logic": false
    },
    {
      "phase": "published-package",
      "status": "separate-step",
      "description": "Publish version 0.1.0 only in a separately approved PyPI release step after repository verification remains green.",
      "contains_engine_logic": false
    }
  ],
  "engine_dependencies": {
    "witnessd": {
      "repository": "Moonweave-Systems/witnessd",
      "role": "execution engine"
    },
    "depone": {
      "repository": "Moonweave-Systems/Depone",
      "role": "verifier engine"
    }
  },
  "required_metadata": [
    "engine-lock/orro-e2e-engine-lock.json",
    "release/orro-release-manifest.v0.json",
    "docs/compatibility-matrix.md",
    "packaging/command-migration-plan.v0.json"
  ],
  "forbidden_scope": [
    "Depone verifier implementation",
    "witnessd runtime implementation",
    "proofcheck implementation",
    "proofrun implementation",
    "scheduler implementation",
    "observer implementation",
    "fan-in implementation",
    "team-ledger verifier implementation"
  ],
  "boundary": {
    "contains_engine_logic": false,
    "implements_proofrun": false,
    "implements_proofcheck": false,
    "creates_third_engine": false,
    "published_package": false,
    "approves_merge": false,
    "raises_assurance": false,
    "depone_verifies": true,
    "witnessd_executes": true,
    "orro_exposes_workflow": true
  },
  "not_proof": true,
  "not_verifier_truth": true,
  "not_package_publish": true
}
